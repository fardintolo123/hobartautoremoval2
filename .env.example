# Quote calculator: optional override for the Make.com webhook URL
# (defaults to the production webhook if unset)
# QUOTE_WEBHOOK_URL=https://hook.eu2.make.com/...

# Optional: Custom labor rate (NZD per hour)
# Defaults to 65 if not set. Common range: 55-75
# PAINTER_LABOR_RATE=65

# Optional: Enable detailed logging for quote system
# DEBUG_QUOTES=false
